{
  "name": "launch-intel",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "nodemon --watch server --watch types.ts --ext ts --exec tsx server/index.ts",
    "dev:web": "vite --config client/vite.config.ts",
    "build": "npm run typecheck && vite build --config client/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ethers": "^6.14.3",
    "express": "^5.1.0",
    "mongoose": "^8.15.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.5"
  }
}
